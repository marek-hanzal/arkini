{
	"name": "arkini",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@10.9.2",
	"scripts": {
		"typecheck:src": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
		"typecheck:test": "tsc -p tsconfig.test.json --noEmit --noUnusedLocals --noUnusedParameters",
		"typecheck": "npm run typecheck:src && npm run typecheck:test",
		"test": "vitest run --no-color",
		"test:shard:1": "vitest run --no-color --shard=1/10",
		"test:shard:2": "vitest run --no-color --shard=2/10",
		"test:shard:3": "vitest run --no-color --shard=3/10",
		"test:shard:4": "vitest run --no-color --shard=4/10",
		"test:shard:5": "vitest run --no-color --shard=5/10",
		"test:shard:6": "vitest run --no-color --shard=6/10",
		"test:shard:7": "vitest run --no-color --shard=7/10",
		"test:shard:8": "vitest run --no-color --shard=8/10",
		"test:shard:9": "vitest run --no-color --shard=9/10",
		"test:shard:10": "vitest run --no-color --shard=10/10",
		"test:shards": "npm run test:shard:1 && npm run test:shard:2 && npm run test:shard:3 && npm run test:shard:4 && npm run test:shard:5 && npm run test:shard:6 && npm run test:shard:7 && npm run test:shard:8 && npm run test:shard:9 && npm run test:shard:10",
		"dc": "depcruise src/engine src/ui cli test --output-type err-long",
		"check": "npm run format:check && npm run dc && npm run typecheck && npm run test",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"game:pack": "tsx cli/arkini.ts pack",
		"game:validate": "tsx cli/arkini.ts validate",
		"game:schema": "tsx cli/arkini.ts schema"
	},
	"dependencies": {
		"@effect/cli": "^0.75.2",
		"@effect/platform": "^0.96.2",
		"@effect/platform-node": "^0.107.0",
		"@msgpack/msgpack": "^3.1.3",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tanstack/react-router": "1.170.15",
		"dexie": "^4.4.4",
		"effect": "^3.21.3",
		"fuse.js": "^7.4.2",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"tailwind-merge": "3.4.0",
		"ts-pattern": "5.9.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"dependency-cruiser": "17.4.2",
		"fake-indexeddb": "^6.2.5",
		"jscpd": "5.0.11",
		"knip": "6.18.0",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.7"
	}
}
