{
	"name": "arkini",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@10.9.2",
	"scripts": {
		"postinstall": "install-electron",
		"arkini": "tsx cli/arkini.ts",
		"predev": "tsx cli/arkini.ts game pack",
		"dev": "electron-vite dev",
		"build": "tsx cli/arkini.ts desktop build",
		"preview": "electron-vite preview",
		"preview:macos": "tsx cli/arkini.ts desktop preview-macos",
		"typecheck:src": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
		"typecheck:test": "tsc -p tsconfig.test.json --noEmit --noUnusedLocals --noUnusedParameters",
		"typecheck:electron": "tsc -p tsconfig.electron.json --noEmit --noUnusedLocals --noUnusedParameters",
		"typecheck": "run-p typecheck:*",
		"test": "vitest run --no-color",
		"test:shard:1": "vitest run --no-color --shard=1/10",
		"test:shard:2": "vitest run --no-color --shard=2/10",
		"test:shard:3": "vitest run --no-color --shard=3/10",
		"test:shard:4": "vitest run --no-color --shard=4/10",
		"test:shard:5": "vitest run --no-color --shard=5/10",
		"test:shard:6": "vitest run --no-color --shard=6/10",
		"test:shard:7": "vitest run --no-color --shard=7/10",
		"test:shard:8": "vitest run --no-color --shard=8/10",
		"test:shard:9": "vitest run --no-color --shard=9/10",
		"test:shard:10": "vitest run --no-color --shard=10/10",
		"test:shards": "run-s test:shard:*",
		"dc": "depcruise src/engine src/bridge src/ui src/page src/@routes src/main.tsx src/router.tsx src/_route.ts electron desktop electron.vite.config.ts cli test --output-type err-long",
		"check": "run-s format:check typecheck game:validate build dc test:shards",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"game:pack": "tsx cli/arkini.ts game pack",
		"game:validate": "tsx cli/arkini.ts game validate",
		"game:schema": "tsx cli/arkini.ts game schema",
		"package:clean": "tsx cli/arkini.ts desktop clean",
		"package:stage": "tsx cli/arkini.ts desktop stage",
		"package:checksums": "tsx cli/arkini.ts desktop checksums",
		"package:verify": "tsx cli/arkini.ts desktop verify",
		"package:mac": "tsx cli/arkini.ts desktop package --arch arm64"
	},
	"dependencies": {
		"@effect/cli": "^0.75.2",
		"@effect/platform": "^0.96.2",
		"@effect/platform-node": "^0.107.0",
		"@msgpack/msgpack": "^3.1.3",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tanstack/react-hotkeys": "^0.10.0",
		"@tanstack/react-query": "5.101.2",
		"@tanstack/react-router": "1.170.15",
		"effect": "^3.21.3",
		"fuse.js": "^7.4.2",
		"motion": "^12.42.2",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"tailwind-merge": "3.4.0",
		"ts-pattern": "5.9.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@iconify-json/lucide": "1.2.118",
		"@iconify/tailwind4": "1.2.3",
		"@tailwindcss/vite": "4.3.0",
		"@tanstack/router-plugin": "1.168.18",
		"@types/node": "24.10.9",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"dependency-cruiser": "17.4.2",
		"electron": "43.1.1",
		"electron-builder": "26.15.3",
		"electron-vite": "6.0.0-beta.1",
		"jscpd": "5.0.11",
		"jsdom": "29.1.1",
		"knip": "6.18.0",
		"npm-run-all2": "8.0.4",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.7"
	},
	"main": "./out/main/index.js",
	"description": "Offline deterministic merge and production game.",
	"author": "Marek Hanzal",
	"engines": {
		"node": "22.16.0",
		"npm": "10.9.2"
	}
}
