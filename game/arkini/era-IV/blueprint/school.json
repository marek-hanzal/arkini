{
	"$schema": "../../../schema.json",
	"items": {
		"item:blueprint-school": {
			"id": "item:blueprint-school",
			"type": "blueprint",
			"title": "School Blueprint",
			"description": "Build plan that can be filled with supplies to construct a School.",
			"asset": {
				"source": [
					"blueprint",
					"producer-school"
				]
			},
			"tags": [
				"blueprint",
				"building",
				"education",
				"knowledge",
				"era:IV"
			],
			"categoryId": "blueprint",
			"scope": "any",
			"maxStackSize": 1,
			"line": {
				"id": "line:blueprint:school:construct",
				"title": "Construct School",
				"description": "Consumes construction resources to build School.",
				"runtimeMs": 32000,
				"input": [
					{
						"type": "materials",
						"selector": {
							"type": "item",
							"itemId": "item:plank"
						},
						"quantity": {
							"type": "value",
							"value": 3
						},
						"charges": {
							"cost": 1,
							"from": "self"
						}
					},
					{
						"type": "materials",
						"selector": {
							"type": "item",
							"itemId": "item:stone-block"
						},
						"quantity": {
							"type": "value",
							"value": 2
						}
					},
					{
						"type": "materials",
						"selector": {
							"type": "item",
							"itemId": "item:paper"
						},
						"quantity": {
							"type": "value",
							"value": 2
						}
					},
					{
						"type": "materials",
						"selector": {
							"type": "item",
							"itemId": "item:coin"
						},
						"quantity": {
							"type": "value",
							"value": 1
						}
					}
				],
				"rules": [
					{
						"type": "enable",
						"when": [
							{
								"type": "exists",
								"query": {
									"scope": "any",
									"selector": {
										"type": "item",
										"itemId": "producer:library-t1"
									}
								}
							}
						]
					}
				],
				"output": {
					"set": [
						{
							"roll": [
								{
									"type": "guaranteed",
									"drop": [
										{
											"itemId": "producer:school",
											"quantity": {
												"type": "value",
												"value": 1
											},
											"placement": "drop",
											"rules": []
										}
									]
								}
							]
						}
					]
				}
			},
			"charges": {
				"amount": 1
			}
		}
	}
}
