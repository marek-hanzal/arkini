{
	"$schema": "../../../arkini.schema.json",
	"items": {
		"item:tree": {
			"description": "Movable tier-1 wood source. Nearby lumberjacks use it for log drop rolls. Harvesting it with a single-use axe removes the source and drops logs.",
			"name": "Tree",
			"removeBy": [
				{
					"itemId": "item:axe",
					"mode": "consume",
					"output": [
						{
							"itemId": "item:log",
							"quantity": 1,
							"type": "guaranteed"
						}
					]
				}
			],
			"tags": [
				"source",
				"wood",
				"era:I",
				"wood-source",
				"tree",
				"tree:t1"
			],
			"tier": 1,
			"capacity": {
				"max": 18,
				"onDepleted": "replace",
				"replaceItemId": "item:seed"
			},
			"maxStackSize": 1
		}
	}
}
