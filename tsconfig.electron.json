{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": [
			"ES2022",
			"DOM"
		],
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"node",
			"electron"
		],
		"resolveJsonModule": true
	},
	"include": [
		"desktop",
		"electron",
		"electron.vite.config.ts"
	]
}
