{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2022"
		],
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"~/*": [
				"./src/*"
			]
		}
	},
	"include": [
		"src",
		"vite.config.ts"
	]
}
