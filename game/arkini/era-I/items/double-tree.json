{
	"$schema": "../../../arkini.schema.json",
	"items": {
		"item:double-tree": {
			"description": "Tier-2 watered wood source: two conifers packed together for stronger nearby lumberjack log rolls. Harvesting it with a single-use axe removes the source and drops logs.",
			"maxStackSize": 1,
			"name": "Double Tree",
			"removeBy": [
				{
					"itemId": "item:axe",
					"mode": "consume",
					"output": [
						{
							"entries": [
								{
									"itemId": "item:log",
									"quantity": {
										"max": 2,
										"min": 1
									},
									"type": "guaranteed"
								}
							]
						}
					]
				}
			],
			"tags": [
				"source",
				"wood",
				"wood-source",
				"tree",
				"tree:t2",
				"era:I"
			],
			"tier": 2,
			"capacity": {
				"max": 36,
				"onDepleted": "replace",
				"replaceItemId": "item:seed"
			}
		}
	}
}
