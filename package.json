{
	"name": "arkini",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@10.9.2",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build --logLevel warn && cp public/.nojekyll dist/.nojekyll",
		"serve": "vite preview",
		"typecheck": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
		"dc": "depcruise src --output-type err-long",
		"test": "vitest run --no-color",
		"check": "npm run format:check && npm run audit:current && npm run game:schema:check && npm run game:validate -- game/arkini && npm run dc && npm run typecheck && npm run test",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"game:compile": "tsx cli/game/compile.ts",
		"game:schema": "tsx cli/game/schema.ts",
		"game:schema:check": "tsx cli/game/schema.ts --check",
		"game:validate": "tsx cli/game/validate.ts",
		"game:validate:default": "npm run game:validate -- game/arkini",
		"audit:dead": "knip --no-exit-code",
		"audit:dupes": "jscpd --config jscpd.json --exit-code 0",
		"audit:optional": "npm run audit:dead && npm run audit:dupes",
		"audit:current": "tsx cli/repo/auditCurrent.ts"
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"@paralleldrive/cuid2": "^3.3.0",
		"@tanstack/react-router": "1.170.15",
		"dexie": "^4.4.4",
		"effect": "^3.21.3",
		"fuse.js": "^7.4.2",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"tailwind-merge": "3.4.0",
		"ts-pattern": "5.9.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"dependency-cruiser": "17.4.2",
		"fake-indexeddb": "^6.2.5",
		"jscpd": "5.0.11",
		"knip": "6.18.0",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.7"
	}
}
