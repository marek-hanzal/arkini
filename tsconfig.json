{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ES2022"
		],
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"~/*": [
				"./src/*"
			]
		},
		"resolveJsonModule": true
	},
	"include": [
		"cli",
		"src/engine",
		"src/ui",
		"src/page",
		"src/@routes",
		"src/main.tsx",
		"src/router.tsx",
		"src/_route.ts",
		"vite.config.ts"
	]
}
