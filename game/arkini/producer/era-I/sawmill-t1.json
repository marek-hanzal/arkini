{
	"$schema": "../../../schema.json",
	"items": {
		"producer:sawmill-t1": {
			"id": "producer:sawmill-t1",
			"type": "producer",
			"title": "Sawmill I",
			"description": "Turns logs into planks when placed near a lumberjack.",
			"asset": {
				"source": [
					"asset:producer:sawmill-t1"
				]
			},
			"tags": [
				"producer",
				"wood",
				"era:I",
				"unique"
			],
			"categoryId": "building",
			"scope": "any",
			"maxCount": 1,
			"maxStackSize": 1,
			"maxQueueSize": 1,
			"lines": [
				{
					"id": "line:sawmill-t1:plank",
					"title": "Plank",
					"description": "Runs plank for Sawmill I.",
					"runtimeMs": 10000,
					"input": [
						{
							"type": "materials",
							"selector": {
								"type": "item",
								"itemId": "item:log"
							},
							"quantity": {
								"type": "value",
								"value": 1
							},
							"capacity": 4
						}
					],
					"rules": [
						{
							"type": "require",
							"when": [
								{
									"type": "exists",
									"query": {
										"scope": "board",
										"distance": "near",
										"selector": {
											"type": "item",
											"itemId": "producer:lumberjack-t1"
										}
									}
								}
							]
						}
					],
					"output": {
						"set": [
							{
								"roll": [
									{
										"type": "guaranteed",
										"drop": [
											{
												"itemId": "item:plank",
												"quantity": {
													"type": "value",
													"value": 2
												},
												"rules": []
											}
										]
									},
									{
										"type": "chance",
										"chance": 0.25,
										"drop": [
											{
												"itemId": "item:plank",
												"quantity": {
													"type": "value",
													"value": 1
												},
												"rules": []
											}
										]
									}
								]
							}
						]
					}
				}
			]
		}
	}
}
