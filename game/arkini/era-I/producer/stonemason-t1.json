{
	"$schema": "../../../schema.json",
	"items": {
		"producer:stonemason-t1": {
			"id": "producer:stonemason-t1",
			"type": "producer",
			"title": "Stonemason I",
			"description": "Turns stone into stone blocks when placed near a quarry.",
			"asset": {
				"source": [
					"asset:producer:stonemason-t1"
				]
			},
			"tags": [
				"producer",
				"stone",
				"era:I",
				"unique"
			],
			"categoryId": "building",
			"scope": "any",
			"maxCount": 1,
			"maxStackSize": 1,
			"maxQueueSize": 1,
			"lines": [
				{
					"id": "line:stonemason-t1:stone-block",
					"title": "Stone Block",
					"description": "Runs stone block for Stonemason I.",
					"runtimeMs": 12000,
					"input": [
						{
							"type": "materials",
							"selector": {
								"type": "item",
								"itemId": "item:stone"
							},
							"quantity": {
								"type": "value",
								"value": 2
							},
							"capacity": 4
						}
					],
					"rules": [
						{
							"type": "enable",
							"when": [
								{
									"type": "exists",
									"query": {
										"scope": "board",
										"distance": "near",
										"selector": {
											"type": "item",
											"itemId": "producer:quarry-t1"
										}
									}
								}
							]
						}
					],
					"output": {
						"set": [
							{
								"roll": [
									{
										"type": "guaranteed",
										"drop": [
											{
												"itemId": "item:stone-block",
												"quantity": {
													"type": "value",
													"value": 1
												},
												"rules": []
											}
										]
									}
								]
							}
						]
					}
				}
			]
		}
	}
}
