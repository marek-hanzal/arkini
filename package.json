{
	"name": "arkini",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@10.9.2",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build --logLevel warn && cp public/.nojekyll dist/.nojekyll",
		"serve": "vite preview",
		"typecheck": "tsc --noEmit",
		"dc": "depcruise src --output-type err-long",
		"test": "vitest run --no-color --pool=forks --maxWorkers=1 --no-file-parallelism",
		"check": "npm run format:check && npm run game:validate -- game/arkini && npm run dc && npm run typecheck && npm run test",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"game:compile": "tsx cli/game/compile.ts",
		"game:validate": "tsx cli/game/validate.ts",
		"game:validate:default": "npm run game:validate -- game/arkini"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-router": "1.170.15",
		"effect": "^3.21.3",
		"kysely": "0.29.2",
		"luxon": "^3.7.2",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"sqlocal": "0.18.0",
		"tailwind-merge": "3.4.0",
		"ts-pattern": "5.9.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/vite": "4.3.0",
		"@types/luxon": "^3.7.1",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"dependency-cruiser": "17.4.2",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.7",
		"tsx": "4.22.4"
	}
}
